generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id        String            @id @default(cuid())
  name      String
  message   String
  rating    Int               @default(5)
  status    TestimonialStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

model Career {
  id           String   @id @default(cuid())
  title        String
  description  String
  requirements String
  applyEmail   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  applications JobApplication[] 
}

model JobApplication {
  id         String   @id @default(cuid())
  careerId   String
  career     Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String
  coverLetter String
  createdAt  DateTime @default(now())
  repliedAt  DateTime?
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  service   String
  message   String
  createdAt DateTime @default(now())
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}